#!/usr/bin/env sh

# ─────────────────────────────────────────────────────────────
# Pre-commit hook: Verify the map build succeeds before commit
# If `npm run build` fails, the commit is blocked.
# ─────────────────────────────────────────────────────────────

echo ""
echo "🔨 Pre-commit: Running build check..."
echo ""

npm run build

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ BUILD FAILED — commit aborted."
  echo "   Fix the build errors above, then try again."
  echo ""
  exit 1
fi

echo ""
echo "✅ Build succeeded — proceeding with commit."
echo ""
